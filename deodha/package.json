{
  "name": "deodha-ecommerce",
  "version": "1.0.0",
  "description": "Deodha - Full Stack E-Commerce Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx nodemon server.js",
    "lint": "eslint src/ --ext .js",
    "test": "jest",
    "build": "echo 'Build completed'",
    "docker:build": "docker build -t deodha-app .",
    "docker:run": "docker run -p 5000:5000 deodha-app",
    "docker:compose": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.4",
    "razorpay": "^2.3.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
